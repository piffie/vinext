{
  "name": "@vinext/types",
  "version": "1.0.0-beta.1",
  "description": "Type declarations for vinext's Next.js-compatible public API.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/vinext.git",
    "directory": "packages/types"
  },
  "files": [
    "next"
